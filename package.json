{
  "name": "pile-patrol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Private, local-first doom-pile triage. Point your phone at a paper pile; keep or kill each item on your Mac; kept items are labeled and filed so the paper is safe to discard. Nothing leaves the house.",
  "engines": { "node": ">=22" },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node hub/server.js",
    "serve": "npm run build && node hub/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "node scripts/eval-route.mjs",
    "verify": "vitest run && node scripts/eval-route.mjs",
    "certs": "node hub/make-certs.mjs"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "jsdom": "^25.0.1",
    "svelte": "^5.19.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.9"
  }
}
